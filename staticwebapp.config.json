{
  "mimeTypes": {
    ".yml": "text/yaml",
    ".yaml": "text/yaml"
  },
  "routes": [
    {
      "route": "/admin/config.yml",
      "allowedRoles": ["anonymous"],
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "route": "/admin/config.yml*",
      "allowedRoles": ["anonymous"],
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "route": "/admin/*",
      "allowedRoles": ["anonymous"],
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    }
  ]
}
