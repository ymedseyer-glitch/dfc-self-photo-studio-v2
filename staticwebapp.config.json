{
  "mimeTypes": {
    ".yml": "text/yaml",
    ".yaml": "text/yaml"
  },
  "routes": [
    {
      "route": "/admin/config.yml",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/admin/config.yml*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/admin/*",
      "allowedRoles": ["anonymous"]
    }
  ]
}
